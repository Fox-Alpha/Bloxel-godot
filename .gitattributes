# Normalize EOL: committed as LF, checked out as OS-native
* text=auto

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.zip binary
*.xcf binary
*.psd binary

# Export builds
*.x86_64 binary
*.exe binary
*.dll binary

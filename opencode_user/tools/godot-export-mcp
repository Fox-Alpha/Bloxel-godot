@app.call_tool()
async def call_tool(name: str, arguments: dict) -> list[TextContent]:
    if name == "export_generate_config":
        return await _handle_generate_config(arguments)
    elif name == "export_build":
        return await _handle_build(arguments)
    else:
        raise ValueError(f"Unknown tool: {name}")


async def _handle_generate_config(args: dict) -> list[TextContent]:
    project_dir = os.path.abspath(args["project_dir"])
    if not os.path.isdir(project_dir):
        return [TextContent(type="text", text=f"Directory not found: {project_dir}")]

    godot_path = _find_godot()
    gv = _get_godot_version(godot_path) if godot_path else ""
    project_name = os.path.basename(project_dir)

    # Show available export presets
    available = _parse_export_presets(project_dir)
    show_only = args.get("show_only", False)

    info_lines: list[str] = []
    info_lines.append(f"Projekt: {project_name}")
    info_lines.append(f"Verzeichnis: {project_dir}")
    info_lines.append(f"Godot: {godot_path or '(nicht gefunden)'} v{gv or '?'}")
    info_lines.append("")

    if available:
        info_lines.append(f"Verfügbare Export-Profile ({len(available)}):")
        for p in available:
            flag = " [default]" if p["name"] in _OS_PROFILE_MAP.get(_detect_os(), "") else ""
            info_lines.append(f"  - {p['name']}  ({p['platform']}, runnable={p['runnable']}){flag}")
    else:
        info_lines.append("Keine export_presets.cfg gefunden.")
        info_lines.append("Erstelle ein Standard-Profil (Linux).")
        info_lines.append("Lege Export-Profile im Godot Editor an (Projekt → Export).")

    if show_only:
        return [TextContent(type="text", text="\n".join(info_lines))]

    # Auto-create missing export presets
    if args.get("profile_names"):
        needed = set(args["profile_names"])
    elif available:
        needed = {p["name"] for p in available}
    else:
        needed = {_OS_PROFILE_MAP.get(_detect_os(), "Windows")}
    created = _ensure_export_presets(project_dir, needed)
    if created:
        info_lines.append(f"\nErstellte fehlende Export-Profile in export_presets.cfg: {', '.join(created)}")
        info_lines.append("(Diese können im Godot Editor angepasst werden.)")
        # Re-parse so config uses fresh presets
        available = _parse_export_presets(project_dir)

    # Generate config with user-selected (or default) profiles
    profile_names = args.get("profile_names", None)
    cfg = _generate_config(project_dir, godot_path, profile_names)
    output_path = args.get("output_path", "")

    result = "\n".join(info_lines)
    result += f"\nGenerierte Profile: {', '.join(p['name'] for p in cfg['profiles'])}"
    result += "\n\n--- build_config.json ---\n"
    result += json.dumps(cfg, indent=2)

    if output_path:
        out = os.path.abspath(output_path)
        os.makedirs(os.path.dirname(out), exist_ok=True)
        with open(out, "w", encoding="utf-8") as f:
            f.write(json.dumps(cfg, indent=2) + "\n")
        result += f"\n\n--- Written to: {out} ---"

    return [TextContent(type="text", text=result)]


async def _handle_build(args: dict) -> list[TextContent]:
    lines: list[str] = []

    # 1. Resolve project directory
    project_dir = args.get("project_dir", "")
    if project_dir:
        project_dir = os.path.abspath(project_dir)
    else:
        found = _find_project_dir()
        if not found:
            return [TextContent(type="text", text=_log("ERROR", "Could not find project.godot. Pass project_dir explicitly."))]
        project_dir = found

    if not os.path.isfile(os.path.join(project_dir, "project.godot")):
        return [TextContent(type="text", text=_log("ERROR", f"project.godot not found in: {project_dir}"))]

    lines.append(_log("INFO", f"Project: {project_dir}"))

    # 2. Load config
    config_path = args.get("config_path", "")
    if config_path:
        config_path = os.path.abspath(config_path)
    else:
        config_path = os.path.join(project_dir, "build_config.json")

    if os.path.isfile(config_path):
        try:
            cfg = _load_config(config_path)
            lines.append(_log("INFO", f"Config loaded: {config_path}"))
        except Exception as e:
            return [TextContent(type="text", text=_log("ERROR", f"Config error: {e}"))]
    elif "profiles" in args and args["profiles"]:
        cfg = {"godot": {"path": "", "version": ""}, "build": dict(_CONFIG_DEFAULTS["build"]),
               "profiles": args["profiles"]}
        lines.append(_log("INFO", "Using inline profiles (no config file)"))
    else:
        return [TextContent(type="text", text=_log("ERROR", f"Config not found: {config_path}. "
                            "Pass config_path or inline profiles."))]

    # 3. Merge overrides into config
    if args.get("godot_path"):
        cfg["godot"]["path"] = args["godot_path"]
    if args.get("godot_version"):
        cfg["godot"]["version"] = args["godot_version"]
    if args.get("project_name"):
        cfg["build"]["project_name"] = args["project_name"]
    if args.get("version_suffix"):
        cfg["build"]["version_suffix"] = args["version_suffix"]
    if args.get("export_root"):
        cfg["build"]["export_root"] = args["export_root"]
    if args.get("export_type"):
        for p in cfg["profiles"]:
            p["type"] = args["export_type"]

    # 4. Find Godot
    godot_path = cfg["godot"]["path"] or _find_godot()
    if not godot_path:
        return [TextContent(type="text", text=_log("ERROR", "Godot executable not found. "
                            "Set godot_path or install Godot in PATH."))]
    resolved = _resolve_godot_path(godot_path)
    if not resolved or not os.access(resolved, os.X_OK):
        return [TextContent(type="text", text=_log("ERROR", f"Godot not found/executable: {godot_path}"))]
    godot_path = resolved
    lines.append(_log("INFO", f"Godot: {godot_path}"))

    # 5. Verify version
    gv_config = _extract_version(cfg["godot"]["version"]) if cfg["godot"]["version"] else ""
    if gv_config:
        actual = _get_godot_version(godot_path)
        if actual is None:
            lines.append(_log("WARN", "Could not determine Godot version"))
        elif actual != gv_config:
            return [TextContent(type="text", text=_log("ERROR",
                                f"Godot version mismatch: expected {gv_config}, got {actual}"))]
        else:
            lines.append(_log("INFO", f"Godot version verified: {actual}"))
    actual_version = _get_godot_version(godot_path) or gv_config

    # 6. Ensure export_presets.cfg exists for all requested profiles
    needed = set(p["name"] for p in cfg["profiles"])
    if args.get("profile"):
        needed = {args["profile"]}
    created = _ensure_export_presets(project_dir, needed)
    if created:
        lines.append(_log("INFO", f"Auto-created export presets: {', '.join(created)}"))

    # 7. Run build
    profile_filter = args.get("profile", "")
    keep_versions = args.get("keep_versions", False)
    build_lines = _run_build(cfg, project_dir, godot_path, actual_version, profile_filter, keep_versions)
    lines += build_lines

    return [TextContent(type="text", text="\n".join(lines))]


async def main() -> None:
    async with stdio_server() as (read_stream, write_stream):
        await app.run(read_stream, write_stream, app.create_initialization_options())


if __name__ == "__main__":
    asyncio.run(main())

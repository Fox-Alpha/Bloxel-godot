# ── Logging helpers ──────────────────────────────────────────────────────────

_LOG_PREFIX = {
    "INFO": "\x1b[32m[INFO]\x1b[0m",
    "WARN": "\x1b[33m[WARN]\x1b[0m",
    "ERROR": "\x1b[31m[ERROR]\x1b[0m",
    "SECTION": "\x1b[34m",
}


def _log(kind: str, msg: str) -> str:
    pfx = _LOG_PREFIX.get(kind, "")
    return f"{pfx} {msg}" if kind != "SECTION" else f"\n{pfx}=== {msg} ===\x1b[0m\n"


# ── OS helpers ───────────────────────────────────────────────────────────────

OS_MAP = {"Linux": "Linux", "Darwin": "Mac", "Windows": "Windows"}
OS_SHORT_MAP = {"Linux": "Lin", "Darwin": "Mac", "Windows": "Win"}


def _detect_os() -> str:
    u = os.uname().sysname
    for pat, val in OS_MAP.items():
        if pat in u:
            return val
    return "Unknown"


def _detect_os_short() -> str:
    u = os.uname().sysname
    for pat, val in OS_SHORT_MAP.items():
        if pat in u:
            return val
    return "Unk"


# ── Godot detection ──────────────────────────────────────────────────────────

_GODOT_CMDS = ["godot", "godot4", "gd4", "godot3", "gd3",
               "/opt/godot/godot", "/snap/bin/godot"]


def _find_godot() -> str | None:
    for cmd in _GODOT_CMDS:
        exe = shutil.which(cmd)
        if exe and os.access(exe, os.X_OK):
            return os.path.realpath(exe)
    return None


def _resolve_godot_path(path: str) -> str | None:
    if os.path.isabs(path):
        return os.path.realpath(path)
    found = shutil.which(path)
    if found:
        return os.path.realpath(found)
    return os.path.realpath(path) if os.path.isfile(path) else path


def _get_godot_version(godot_path: str) -> str | None:
    try:
        out = subprocess.check_output([godot_path, "--version"],
                                      stderr=subprocess.STDOUT, text=True)
        m = re.search(r"(\d+)\.(\d+)", out.splitlines()[0])
        return f"{m.group(1)}.{m.group(2)}" if m else None
    except Exception:
        return None


def _find_project_dir(start: str | None = None) -> str | None:
    d = os.path.abspath(start or os.getcwd())
    while True:
        if os.path.isfile(os.path.join(d, "project.godot")):
            return d
        parent = os.path.dirname(d)
        if parent == d:
            return None
        d = parent



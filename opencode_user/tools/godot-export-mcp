def _extract_version(raw: str) -> str:
    m = re.search(r"(\d+\.\d+)", raw)
    return m.group(1) if m else raw


def _load_config(path: str) -> dict:
    with open(path, encoding="utf-8") as f:
        cfg: dict = json.load(f)
    godot = cfg.get("godot", {})
    build = cfg.get("build", {})
    profiles = cfg.get("profiles", [])

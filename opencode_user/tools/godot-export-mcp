application/product_version=""
application/company_name=""
application/product_name=""
application/file_description=""
application/copyright=""
application/trademarks=""
dotnet/include_script_code=true
"""


def _ensure_export_presets(
    project_dir: str, needed: set[str],
) -> list[str]:
    path = os.path.join(project_dir, "export_presets.cfg")
    existing = {p["name"] for p in _parse_export_presets(project_dir)}
    missing = needed - existing
    if not missing:
        return []

    platform_map = {
        "Linux": "Linux",
        "Windows": "Windows Desktop",
        "Mac": "Mac OSX",
        "Web": "Web",
    }
    created: list[str] = []
    with open(path, "a" if os.path.isfile(path) else "w") as f:
        for name in sorted(missing):
            idx = len(existing) + len(created)
            platform = platform_map.get(name, name)
            f.write(_MINIMAL_PRESET_TPL.format(index=idx, name=name, platform=platform))
            created.append(name)
    return created


# ── Generate default config ──────────────────────────────────────────────────

_OS_PROFILE_MAP = {"Linux": "Linux", "Mac": "Web", "Windows": "Windows", "Unknown": "Windows"}


def _generate_config(
    project_dir: str,
    godot_path: str | None,
    profile_names: list[str] | None = None,
) -> dict:
    project_name = os.path.basename(os.path.abspath(project_dir))
    gv = _get_godot_version(godot_path) if godot_path else ""

    # Build profiles from export_presets.cfg or OS default
    available = _parse_export_presets(project_dir)
    if profile_names:
        names_set = set(profile_names)
        chosen = [p for p in available if p["name"] in names_set]
        if not chosen:
            chosen = [{"name": n, "platform": "x86_64", "runnable": False}
                      for n in profile_names]
    elif available:
        os_name = _detect_os()
        default_name = _OS_PROFILE_MAP.get(os_name, "Windows")
        chosen = [p for p in available if p["name"] == default_name]
        if not chosen:
            chosen = [available[0]]
    else:
        os_name = _detect_os()
        default_name = _OS_PROFILE_MAP.get(os_name, "Windows")
        chosen = [{"name": default_name, "platform": "x86_64", "runnable": False}]

    profiles = []
    for p in chosen:
        profiles.append({
            "name": p["name"],
            "type": "export-debug",
            "platform": p.get("platform", "x86_64"),
            "output_filename": "",
            "export_path": "",
        })

    return {
        "godot": {"path": godot_path or "", "version": gv},
        "build": {
            "project_name": project_name,
            "version_suffix": "dev",
            "export_root": ".exports",
            "export_path": "",
            "output_filename": "{project}_{date}_{os}_{type}",
            "use_separators": True,
        },
        "profiles": profiles,
    }



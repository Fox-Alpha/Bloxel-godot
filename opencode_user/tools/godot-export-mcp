# ── Filename generation ──────────────────────────────────────────────────────

_EXTENSIONS = {
    "Windows": ".exe",
    "Linux": ".x86_64",
    "Mac": ".x86_64",
}


_PROFILE_OS_MAP = {
    "Linux": "Lin", "Windows": "Win", "Mac": "Mac", "Web": "Web",
    "Android": "And", "iOS": "iOS",
}


def _target_os_short(profile_name: str) -> str:
    for key, val in _PROFILE_OS_MAP.items():
        if key.lower() in profile_name.lower():
            return val
    return _detect_os_short()


def _generate_filename(
    template: str,
    project_name: str,
    version_suffix: str,
    godot_version: str,
    os_short: str,
    export_type: str,
    profile_name: str,
    platform: str,
    use_separators: bool,
) -> str:
    type_short = export_type.replace("export-", "", 1)
    subs = {
        "{project}": project_name,
        "{version_suffix}": version_suffix,
        "{platform}": platform,
        "{os}": _target_os_short(profile_name),
        "{godot_version}": godot_version or "unknown",
        "{date}": date.today().strftime("%Y%m%d"),
        "{type}": type_short,
    }
    fn = template
    for k, v in subs.items():
        fn = fn.replace(k, str(v))
    if not use_separators:
        fn = fn.replace("_", "")
    fn = re.sub(r"_+", "_", fn)
    return fn


# ── Resolve export path ──────────────────────────────────────────────────────

def _resolve_export_path(
    export_path: str, export_root: str, project_dir: str
) -> str:
    raw = export_path or export_root
    if os.path.isabs(raw):
        return raw
    return os.path.normpath(os.path.join(project_dir, raw))


# ── Export execution ─────────────────────────────────────────────────────────

def _run_import(godot_path: str, project_dir: str, log_file: str) -> list[str]:
    lines: list[str] = []
    lines.append(_log("SECTION", "Resource Import Phase"))
    cmd = [godot_path, "--verbose", "--import", "--headless"]
    lines.append(_log("INFO", f"Command: {' '.join(cmd)}"))
    try:
        with open(log_file, "w") as lf:
            rc = subprocess.run(cmd, cwd=project_dir,
                                stdout=lf, stderr=subprocess.STDOUT).returncode
        if rc != 0:
            with open(log_file) as lf:
                tail = "".join(lf.readlines()[-20:])
            lines.append(_log("ERROR", f"Import failed (rc={rc}):\n{tail}"))
            return lines
        lines.append(_log("INFO", "Import completed"))
    except FileNotFoundError:
        lines.append(_log("ERROR", "Godot executable not found for import"))
    except Exception as e:
        lines.append(_log("ERROR", f"Import crashed: {e}"))
    return lines


def _run_export(
    godot_path: str, project_dir: str,
    profile_name: str, export_type: str,
    output_path: str, log_file: str,
) -> list[str]:
    lines: list[str] = []
    lines.append(_log("INFO", f"Exporting profile '{profile_name}' ({export_type})"))
    export_flag = f"--{export_type}"
    cmd = [godot_path, "--verbose", "--headless",
           export_flag, profile_name, "--path", project_dir, output_path]
    lines.append(_log("INFO", f"Command: {' '.join(cmd)}"))
    try:
        with open(log_file, "w") as lf:
            rc = subprocess.run(cmd, cwd=project_dir,
                                stdout=lf, stderr=subprocess.STDOUT).returncode
        if rc != 0:
            with open(log_file) as lf:
                tail = "".join(lf.readlines()[-20:])
            lines.append(_log("ERROR", f"Export failed (rc={rc}):\n{tail}"))
            return lines
        lines.append(_log("INFO", "Export completed"))
    except FileNotFoundError:
        lines.append(_log("ERROR", "Godot executable not found for export"))
    except Exception as e:
        lines.append(_log("ERROR", f"Export crashed: {e}"))
    return lines


# ── Build orchestrator ───────────────────────────────────────────────────────

def _next_version(path: str) -> str:
    base, ext = os.path.splitext(path)
    m = re.search(r"_(\d{3})$", base)
    if m:
        n = int(m.group(1)) + 1
        stem = base[:m.start()]
    else:
        stem = base
        n = 1
    candidate = f"{stem}_{n:03d}{ext}"
    while os.path.isfile(candidate):
        n += 1
        candidate = f"{stem}_{n:03d}{ext}"
    return candidate


def _build_log_path(output_path: str) -> str:
    base, _ = os.path.splitext(output_path)
    return base + ".log"


def _run_build(cfg: dict, project_dir: str, godot_path: str,
               godot_version: str, profile_filter: str | None,
               keep_versions: bool = False) -> list[str]:
    lines: list[str] = []
    build = cfg["build"]
    profiles = cfg["profiles"]

    project_name = build["project_name"]
    version_suffix = build["version_suffix"]
    export_root = build["export_root"]
    export_path = build["export_path"]
    output_template = build["output_filename"]
    use_separators = build["use_separators"]
    os_short = _detect_os_short()

    # Resolve base export directory
    base_export_dir = _resolve_export_path(export_path, export_root, project_dir)
    import_log = os.path.join(project_dir, ".import.log.txt")

    # Import once
    lines += _run_import(godot_path, project_dir, import_log)

    # Process profiles
    filtered = [p for p in profiles
                if not profile_filter or p["name"] == profile_filter]

    for p in filtered:
        p_name: str = p["name"]
        p_type: str = p.get("type", "export-debug")
        p_platform: str = p.get("platform", "x86_64")
        p_filename: str = p.get("output_filename", "") or output_template
        p_path: str = p.get("export_path", "") or ""

        lines.append(_log("SECTION", f"Profile: {p_name}"))
        lines.append(_log("INFO", f"Type: {p_type}"))
        lines.append(_log("INFO", f"Platform: {p_platform}"))

        # Resolve per-profile export dir
        profile_dir = _resolve_export_path(p_path, export_root, project_dir)
        profile_dir = os.path.join(profile_dir, p_name)
        os.makedirs(profile_dir, exist_ok=True)
        lines.append(_log("INFO", f"Export dir: {profile_dir}"))

        # Generate filename
        base_fn = _generate_filename(
            p_filename, project_name, version_suffix,
            godot_version, os_short, p_type, p_name, p_platform, use_separators,
        )

        # Suffix separator
        suffix_sep = "_" if (use_separators and version_suffix
                             and not version_suffix.startswith("_")) else ""

        # Extension
        ext = _EXTENSIONS.get(p_name, "")
        output_name = f"{base_fn}{suffix_sep}{version_suffix}{ext}"
        output_path = os.path.join(profile_dir, output_name)
        build_log = _build_log_path(output_path)

        # Version counter when file exists
        if keep_versions and os.path.isfile(output_path):
            output_path = _next_version(output_path)
            build_log = _build_log_path(output_path)
            lines.append(_log("INFO", f"Output (v2+): {os.path.basename(output_path)}"))
        elif os.path.isfile(output_path):
            os.remove(output_path)
            lines.append(_log("INFO", "Removed old binary"))
        else:
            lines.append(_log("INFO", f"Output: {os.path.basename(output_path)}"))

        # Export
        lines += _run_export(godot_path, project_dir, p_name, p_type,
                             output_path, build_log)

        # Verify
        if os.path.isfile(output_path):
            size = os.path.getsize(output_path)
            size_hr = f"{size:,} bytes"
            if size > 1024 * 1024:
                size_hr = f"{size / 1024 / 1024:.1f} MiB"
            elif size > 1024:
                size_hr = f"{size / 1024:.1f} KiB"
            lines.append(_log("INFO", f"Binary size: {size_hr}"))
            if p_name in ("Linux", "Mac"):
                os.chmod(output_path, 0o755)
                lines.append(_log("INFO", "Made executable"))
        else:
            lines.append(_log("ERROR", f"Binary not found: {output_path}"))

    lines.append(_log("SECTION", "Build Complete"))
    lines.append(_log("INFO", f"Exports in: {base_export_dir}"))
    return lines


# ── Parse export_presets.cfg ─────────────────────────────────────────────────

def _parse_export_presets(project_dir: str) -> list[dict]:
    path = os.path.join(project_dir, "export_presets.cfg")
    if not os.path.isfile(path):
        return []
    presets: list[dict] = []
    with open(path, encoding="utf-8") as f:
        current: dict | None = None
        for line in f:
            line = line.strip()
            m = re.match(r'^\[preset\.(\d+)\]$', line)
            if m:
                if current:
                    presets.append(current)
                current = {"index": int(m.group(1)), "name": "", "platform": "",
                           "runnable": False}
            elif current and line.startswith("name="):
                val = line.split("=", 1)[1].strip("\"")
                current["name"] = val
            elif current and line.startswith("platform="):
                val = line.split("=", 1)[1].strip("\"")
                current["platform"] = val
            elif current and line.startswith("runnable="):
                current["runnable"] = line.split("=", 1)[1].strip() == "true"
        if current:
            presets.append(current)
    return presets



# ── LSP client ──────────────────────────────────────────────────────────────

FORMATTER_BIN = shutil.which("gdscript-formatter")
LSP_PORTS = [6005, 6007, 6008]
LSP_HOST = os.environ.get("GODOT_LSP_HOST", "127.0.0.1")


class LspError(Exception):
    def __init__(self, code: int, message: str, data: Any = None):
        self.code = code
        self.message = message
        self.data = data


class LspClient:
    """Raw TCP connection to Godot's GDScript LSP server."""

    RECONNECT_DELAY = 3.0
    MAX_RETRIES = 60  # keep trying for ~3 minutes

    def __init__(self):
        self.sock: socket.socket | None = None
        self._buf = b""
        self._req_id = 0
        self._pending: dict[int, asyncio.Future] = {}
        self._reader_task: asyncio.Task | None = None
        self._loop: asyncio.AbstractEventLoop | None = None
        self._diag_futures: dict[str, asyncio.Future] = {}
        self._opened_uris: set[str] = set()
        self._connected = False

    async def connect(self) -> None:
        await self._try_connect_socket()
        self._loop = asyncio.get_event_loop()
        self._reader_task = asyncio.create_task(self._read_loop())
        await self._send_initialize()

    async def _try_connect_socket(self) -> None:
        for port in LSP_PORTS:
            try:
                s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                s.settimeout(2.0)
                s.connect((LSP_HOST, port))
                s.settimeout(None)
                s.setblocking(False)
                self.sock = s
                self._connected = True
                print(f"LSP: connected on port {port}", file=sys.stderr)
                return
            except (OSError, ConnectionRefusedError):
                continue
        self._connected = False
        raise ConnectionError(
            f"Could not connect to Godot LSP on ports {LSP_PORTS}"
        )

    async def _send_initialize(self) -> None:
        root = f"file://{os.getcwd()}"
        caps = await self._request("initialize", {
            "processId": None,
            "rootPath": os.getcwd(),
            "rootUri": root,
            "clientInfo": {"name": "godot-lsp-mcp", "version": "1.0.0"},
            "capabilities": {},
        })
        await self._notify("initialized", {})
        print(
            f"LSP: initialized (server: {caps.get('serverInfo', {})})",
            file=sys.stderr,
        )

    async def _ensure_connected(self) -> None:
        if self._connected:
            return
        print("LSP: reconnecting...", file=sys.stderr)
        self._opened_uris.clear()
        if self._reader_task and not self._reader_task.done():
            self._reader_task.cancel()
        for _ in range(self.MAX_RETRIES):
            await asyncio.sleep(self.RECONNECT_DELAY)
            try:
                await self._try_connect_socket()
                self._reader_task = asyncio.create_task(self._read_loop())
                await self._send_initialize()
                print("LSP: reconnected", file=sys.stderr)
                return
            except (OSError, ConnectionError):
                continue
        raise ConnectionError("LSP: could not reconnect to Godot LSP")

    async def close(self) -> None:
        if self._reader_task:
            self._reader_task.cancel()
        if self.sock:
            try:
                self.sock.close()
            except OSError:
                pass

    # ── LSP convenience methods ──────────────────────────────────────────

    async def _ensure_open(self, path: str, language: str = "gdscript") -> str:
        uri = self._path_to_uri(path)
        if uri in self._opened_uris:
            return uri
        with open(path, encoding="utf-8") as f:
            text = f.read()
        await self._notify("textDocument/didOpen", {
            "textDocument": {
                "uri": uri,
                "languageId": language,
                "version": 1,
                "text": text,
            }
        })
        self._opened_uris.add(uri)
        return uri

    async def open_document(self, path: str, language: str = "gdscript") -> None:
        await self._ensure_open(path, language)

    async def get_diagnostics(self, path: str) -> list[dict]:
        uri = await self._ensure_open(path)
        fut = self._loop.create_future()
        self._diag_futures[uri] = fut
        try:
            diags = await asyncio.wait_for(fut, timeout=5.0)
            return diags
        except asyncio.TimeoutError:
            return []
        except Exception:
            return []

    async def get_document_symbols(self, path: str) -> list[dict]:
        uri = self._path_to_uri(path)
        result = await self._request("textDocument/documentSymbol", {
            "textDocument": {"uri": uri},
        })
        return result if isinstance(result, list) else []

    async def get_hover(self, path: str, line: int, col: int) -> dict | None:
        uri = self._path_to_uri(path)
        result = await self._request("textDocument/hover", {
            "textDocument": {"uri": uri},
            "position": {"line": line, "character": col},
        })
        return result if result else None

    async def get_completions(
        self, path: str, line: int, col: int
    ) -> list[dict]:
        uri = self._path_to_uri(path)
        result = await self._request("textDocument/completion", {
            "textDocument": {"uri": uri},
            "position": {"line": line, "character": col},
            "context": {"triggerKind": 1},
        })
        if isinstance(result, dict):
            return result.get("items", result.get("itemDefaults", []))
        return result if isinstance(result, list) else []

    # ── Internal LSP messaging ───────────────────────────────────────────

    async def _request(self, method: str, params: dict) -> Any:
        self._req_id += 1
        req_id = self._req_id
        fut = self._loop.create_future()
        self._pending[req_id] = fut
        await self._send({"jsonrpc": "2.0", "id": req_id, "method": method, "params": params})
        return await fut

    async def _notify(self, method: str, params: dict) -> None:
        await self._send({"jsonrpc": "2.0", "method": method, "params": params})

    async def _send(self, msg: dict) -> None:
        await self._ensure_connected()
        data = json.dumps(msg, ensure_ascii=False)
        framed = f"Content-Length: {len(data.encode())}\r\n\r\n{data}".encode()
        try:
            await self._loop.sock_sendall(self.sock, framed)
        except (OSError, ConnectionError) as e:
            self._connected = False
            raise ConnectionError(f"LSP send failed: {e}")

    async def _read_loop(self) -> None:
        while True:
            try:
                data = await self._loop.sock_recv(self.sock, 65536)
                if not data:
                    break
                self._buf += data
                self._process_buf()
            except (OSError, ConnectionError) as e:
                print(f"LSP: connection error: {e}", file=sys.stderr)
                break
        self._connected = False
        print("LSP: connection lost", file=sys.stderr)

    def _process_buf(self) -> None:
        while True:
            header_end = self._buf.find(b"\r\n\r\n")
            if header_end == -1:
                break
            header = self._buf[:header_end].decode(errors="replace")
            length = self._parse_content_length(header)
            if length is None or length <= 0:
                self._buf = self._buf[header_end + 4 :]
                continue
            body_start = header_end + 4
            body_end = body_start + length
            if len(self._buf) < body_end:
                break
            body = self._buf[body_start:body_end]
            self._buf = self._buf[body_end:]
            self._handle_message(body)

    def _parse_content_length(self, header: str) -> int | None:
        for line in header.split("\n"):
            line = line.strip()
            if line.lower().startswith("content-length:"):
                try:
                    return int(line.split(":")[1].strip())
                except (ValueError, IndexError):
                    return None
        return None

    def _handle_message(self, raw: bytes) -> None:
        try:
            msg = json.loads(raw)
        except json.JSONDecodeError:
            return

        if isinstance(msg, dict):
            # Push diagnostics notification
            if msg.get("method") == "textDocument/publishDiagnostics":
                uri = msg.get("params", {}).get("uri", "")
                if uri in self._diag_futures:
                    fut = self._diag_futures.pop(uri)
                    if not fut.done():
                        fut.set_result(msg["params"].get("diagnostics", []))
                return

            if "id" in msg and msg["id"] is not None:
                req_id = msg["id"]
                fut = self._pending.pop(req_id, None)
                if fut and not fut.done():
                    if "error" in msg:
                        err = msg["error"]
                        fut.set_exception(
                            LspError(err.get("code", -1), err.get("message", ""))
                        )
                    else:
                        fut.set_result(msg.get("result"))

    @staticmethod
    def _path_to_uri(path: str) -> str:
        abs_path = os.path.abspath(path)
        return f"file://{abs_path}"



def _fmt_symbol(sym: dict, indent: str = "") -> str:
    name = sym.get("name", "?")
    kind = sym.get("kind", 0)
    kind_names = {
        1: "File", 2: "Module", 3: "Namespace", 4: "Package", 5: "Class",
        6: "Method", 7: "Property", 8: "Field", 9: "Constructor",
        10: "Enum", 11: "Interface", 12: "Function", 13: "Variable",
        14: "Constant", 15: "String", 16: "Number", 17: "Boolean",
        18: "Array", 19: "Object", 20: "Key", 21: "Null",
        22: "EnumMember", 23: "Struct", 24: "Event", 25: "Operator",
        26: "TypeParameter",
    }
    kind_str = kind_names.get(kind, f"kind_{kind}")
    result = f"{indent}{kind_str} `{name}`"
    if sym.get("detail"):
        result += f"  ({sym['detail']})"
    result += f"  [L{sym.get('range', {}).get('start', {}).get('line', '?')}]"
    if sym.get("children"):
        for child in sym["children"]:
            result += "\n" + _fmt_symbol(child, indent + "  ")
    return result



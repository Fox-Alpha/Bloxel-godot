@app.call_tool()
async def call_tool(name: str, arguments: dict) -> list[TextContent]:
    path = os.path.abspath(arguments.get("path", ""))

    if name == "generate_changelog":
        return await _handle_changelog(arguments)

    if name in ("gdscript_format", "gdscript_lint"):
        if not os.path.exists(path):
            return [TextContent(type="text", text=f"File not found: {path}")]
        if name == "gdscript_format":
            return await _handle_format(path, arguments.get("check_only", False))
        elif name == "gdscript_lint":
            return await _handle_lint(path, arguments.get("max_line_length", 100))

    if not os.path.exists(path):
        return [TextContent(type="text", text=f"File not found: {path}")]

    try:
        await lsp._ensure_connected()
        await lsp.open_document(path)
    except ConnectionError as e:
        return [TextContent(type="text", text=f"LSP nicht verbunden. Stelle sicher, dass der Godot Editor läuft und das Projekt geöffnet ist.\n\nFehler: {e}")]
    except Exception as e:
        return [TextContent(type="text", text=f"Failed to open document in LSP: {e}")]

    if name == "godot_lsp_diagnostics":
        return await _handle_diagnostics(path)
    elif name == "godot_lsp_symbols":
        return await _handle_symbols(path)
    elif name == "godot_lsp_hover":
        return await _handle_hover(path, arguments)
    else:
        raise ValueError(f"Unknown tool: {name}")


async def _handle_diagnostics(path: str) -> list[TextContent]:
    try:
        diags = await lsp.get_diagnostics(path)
    except Exception as e:
        return [TextContent(type="text", text=f"LSP diagnostics error: {e}")]

    if not diags:
        return [TextContent(type="text", text="No diagnostics found.")]

    sev_names = {1: "ERROR", 2: "WARNING", 3: "INFO", 4: "HINT"}
    lines = [f"Diagnostics for {path}:"]
    for d in diags:
        sev = sev_names.get(d.get("severity", 0), "?")
        rng = d.get("range", {})
        start = rng.get("start", {})
        loc = f"L{start.get('line', '?')}:{start.get('character', '?')}"
        msg = d.get("message", "")
        src = d.get("source", "")
        src_str = f" [{src}]" if src else ""
        lines.append(f"  [{sev}] {loc}{src_str}: {msg}")

    return [TextContent(type="text", text="\n".join(lines))]


async def _handle_symbols(path: str) -> list[TextContent]:
    try:
        symbols = await lsp.get_document_symbols(path)
    except Exception as e:
        return [TextContent(type="text", text=f"LSP symbols error: {e}")]

    if not symbols:
        return [TextContent(type="text", text="No symbols found.")]

    result = "\n".join(_fmt_symbol(s) for s in symbols)
    return [TextContent(type="text", text=f"Symbols for {path}:\n{result}")]


async def _handle_hover(path: str, args: dict) -> list[TextContent]:
    line = args["line"]
    col = args["column"]
    try:
        hover = await lsp.get_hover(path, line, col)
    except Exception as e:
        return [TextContent(type="text", text=f"LSP hover error: {e}")]

    if not hover:
        return [TextContent(type="text", text="No hover info available at this position.")]

    contents = hover.get("contents", {})
    if isinstance(contents, str):
        text = contents
    elif isinstance(contents, dict):
        text = contents.get("value", json.dumps(contents, indent=2))
    elif isinstance(contents, list):
        parts = []
        for c in contents:
            if isinstance(c, str):
                parts.append(c)
            elif isinstance(c, dict):
                parts.append(c.get("value", json.dumps(c)))
        text = "\n".join(parts)
    else:
        text = json.dumps(contents, indent=2)

    rng = hover.get("range", {})
    rng_str = ""
    if rng:
        s = rng.get("start", {})
        e = rng.get("end", {})
        rng_str = f" [L{s.get('line')}:{s.get('character')} - L{e.get('line')}:{e.get('character')}]"

    return [
        TextContent(
            type="text",
            text=f"Hover at L{line}:{col}{rng_str}:\n{text}",
        )
    ]


def _check_formatter() -> str | None:
    if not FORMATTER_BIN:
        return (
            "`gdscript-formatter` not found in PATH.\n"
            "Install it from github.com/Fox-Alpha/godot-dev-toolkit or place the binary in PATH."
        )
    return None


async def _run_cli(args: list[str], cwd: str | None = None) -> tuple[int, str, str]:
    proc = await asyncio.create_subprocess_exec(
        *args,
        cwd=cwd,
        stdout=asyncio.subprocess.PIPE,
        stderr=asyncio.subprocess.PIPE,
    )
    stdout, stderr = await proc.communicate()
    return proc.returncode or 0, stdout.decode(), stderr.decode()


async def _handle_format(path: str, check_only: bool) -> list[TextContent]:
    err = _check_formatter()
    if err:
        return [TextContent(type="text", text=err)]

    if check_only:
        rc, out, err = await _run_cli(
            [FORMATTER_BIN, "--check", path]
        )
        if rc == 0:
            return [TextContent(type="text", text="File is properly formatted.")]
        rc2, out2, _ = await _run_cli(
            [FORMATTER_BIN, "--stdout", path]
        )
        return [TextContent(
            type="text",
            text=f"File is NOT formatted.\n\nExpected formatting:\n{out2}",
        )]
    else:
        rc, _, err = await _run_cli(
            [FORMATTER_BIN, "--reorder-code", "-s", path]
        )
        if rc != 0:
            return [TextContent(type="text", text=f"Format error:\n{err}")]
        return [TextContent(type="text", text=f"Formatted: {path}")]


async def _handle_lint(path: str, max_line_length: int) -> list[TextContent]:
    err = _check_formatter()
    if err:
        return [TextContent(type="text", text=err)]

    rc, out, err = await _run_cli(
        [FORMATTER_BIN, "lint", "--max-line-length", str(max_line_length), "--pretty", path]
    )
    if not out and not err:
        return [TextContent(type="text", text="No lint issues found.")]
    if out:
        return [TextContent(type="text", text=out)]
    return [TextContent(type="text", text=err)]


PREFIX_ORDER = ["Add", "Fix", "Upd", "Chg", "Del", "Docs", "Ref", "Mve", "Rem", "Ren"]


def _detect_prefix(msg: str) -> tuple[str, str]:
    for p in PREFIX_ORDER:
        if msg.startswith(p + ":") or msg.startswith(p + " "):
            return p, msg[len(p) + 1:].strip()
    return "", msg


async def _handle_changelog(args: dict) -> list[TextContent]:
    repo_path = args.get("repo_path", "")
    path = args.get("path", "-")
    branch = args.get("branch", "")
    since = args.get("since", "")
    until_arg = args.get("until", "")
    title = args.get("title", "")
    cwd = os.path.abspath(repo_path) if repo_path else None

    cmd = ["git", "log", "--pretty=format:%ad|%h|%s", "--date=short"]
    if branch:
        cmd.append(branch)
    if since:
        cmd += [f"--since={since}"] if re.match(r"^\d{4}-\d{2}-\d{2}$", since) else [f"{since}..HEAD"]
    if until_arg:
        if re.match(r"^\d{4}-\d{2}-\d{2}$", until_arg):
            cmd += [f"--until={until_arg}"]
        elif since and not re.match(r"^\d{4}-\d{2}-\d{2}$", since):
            cmd = [f"{since}..{until_arg}"]
        else:
            cmd.append(until_arg)
    if path and path != "-":
        cmd += ["--", path]

    rc, stdout, stderr = await _run_cli(cmd, cwd=cwd)
    if rc != 0 or not stdout.strip():
        return [TextContent(type="text", text=f"No git history found for '{path or 'repo'}'.")]

    entries: list[dict] = []
    for line in stdout.splitlines():
        parts = line.split("|", 2)
        if len(parts) >= 3:
            entries.append({"date": parts[0], "hash": parts[1], "msg": parts[2]})

    groups: dict[str, list[dict]] = {}
    for e in entries:
        groups.setdefault(e["date"], []).append(e)

    remote = await _get_remote_url(cwd=cwd)
    repo_dir = cwd or os.getcwd()
    repo_name = os.path.basename(repo_dir)

    if not title:
        br = branch or await _get_current_branch(cwd=cwd)
        title = f"{repo_name} ({br})" if br else repo_name

    lines = [f"# {title}", ""]
    lines.append(
        "Die folgenden Einträge wurden automatisch aus der Git-Historie generiert. "
        "Die Reihenfolge der Typen ist Add → Fix → Upd → Chg → Del → Docs → Ref → Mve → Rem → Ren → sonstige."
    )
    lines.append("")

    for date, ents in groups.items():
        lines.append(f"## {date}")
        lines.append("")
        sorted_ents = sorted(
            ents,
            key=lambda e: (
                PREFIX_ORDER.index(_detect_prefix(e["msg"])[0])
                if _detect_prefix(e["msg"])[0] in PREFIX_ORDER
                else len(PREFIX_ORDER)
            ),
        )
        for e in sorted_ents:
            msg = e["msg"]
            link = f" [{e['hash']}]({remote}/commit/{e['hash']})" if remote else f" {e['hash']}"
            lines.append(f"- {msg}{link}")
        lines.append("")

    output_path = args.get("output", "")
    if output_path:
        os.makedirs(os.path.dirname(os.path.abspath(output_path)) or ".", exist_ok=True)
        with open(output_path, "w", encoding="utf-8") as f:
            f.write("\n".join(lines))
        result = "\n".join(lines) + f"\n\n--- Written to: {output_path} ---"
    else:
        result = "\n".join(lines)

    return [TextContent(type="text", text=result)]


async def _get_remote_url(*, cwd: str | None = None) -> str:
    rc, out, _ = await _run_cli(["git", "config", "--get", "remote.origin.url"], cwd=cwd)
    return out.strip() if rc == 0 else ""


async def _get_current_branch(*, cwd: str | None = None) -> str:
    rc, out, _ = await _run_cli(["git", "branch", "--show-current"], cwd=cwd)
    return out.strip() if rc == 0 else ""


async def main() -> None:
    async with stdio_server() as (read_stream, write_stream):
        await app.run(read_stream, write_stream, app.create_initialization_options())


if __name__ == "__main__":
    asyncio.run(main())

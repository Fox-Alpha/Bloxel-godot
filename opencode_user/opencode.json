{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "opencode/deepseek-v4-flash-free",
	"permission": {
		"bash": {
			"*": "ask",
			"ls *": "allow",
			"cat *": "allow",
			"find *": "allow",
			"grep *": "allow",
			"rg *": "allow",
			"mkdir *": "allow",
			"cp *": "allow",
			"touch *": "allow",
			"chmod *": "allow",
			"echo *": "allow",
			"head *": "allow",
			"tail *": "allow",
			"sort *": "allow",
			"sed *": "allow",
			"wc *": "allow",
			"which *": "allow",
			"git *": "allow",
			"git merge *": "ask",
			"git push *": "ask",
			"git reset *": "deny",
			"git clean *": "deny",
			"git rebase *": "deny",
			"rm *": "ask",
			"mv *": "ask",
			"sudo *": "deny"
		},
		"skill": {
			"*": "ask",
			"new-godot-project": "allow"
		},
		"external_directory": {
				"/**": "deny",
				"~/.config/opencode/**": "allow",
				"~/Projekte/Godot/**": "ask"
		},
		"edit": {
			"~/.config/opencode/**": "deny",
			"~/.config/opencode/opencode.json": "ask"
		},
		"glob": {
			"~/.config/opencode/**" : "ask"
		},
		"read": {
			"~/.config/opencode/templates/godot/*" : "allow"
		}

	},
	"instructions": [
		"instructions/communication.md",
		"instructions/workflow.md"
	],
	"skills": {
		"paths": ["~/.config/opencode/skills"]
	},
  "mcp": {}
}
